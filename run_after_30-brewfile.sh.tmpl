{{ if eq .chezmoi.os "darwin" -}}
#!/bin/bash
# Install Homebrew packages from Brewfile (non-interactive, skip already installed)

BREWFILE="{{ .chezmoi.sourceDir }}/Brewfile"

if command -v brew &>/dev/null && [ -f "$BREWFILE" ]; then
  brew bundle --file="$BREWFILE" --no-upgrade 2>/dev/null
fi
{{ end -}}
