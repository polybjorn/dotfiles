<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.bjanda.obsidian-weekly-note</string>
  <key>ProgramArguments</key>
  <array>
    <string>/usr/bin/python3</string>
    <string>__HOME__/Vault/Obsidian/Extras/Scripts/obsidian-weekly-note.py</string>
  </array>
  <key>StartCalendarInterval</key>
  <dict>
    <key>Weekday</key>
    <integer>1</integer>
    <key>Hour</key>
    <integer>0</integer>
    <key>Minute</key>
    <integer>5</integer>
  </dict>
  <key>StandardOutPath</key>
  <string>__HOME__/Library/Logs/obsidian-weekly-note.log</string>
  <key>StandardErrorPath</key>
  <string>__HOME__/Library/Logs/obsidian-weekly-note.log</string>
</dict>
</plist>
