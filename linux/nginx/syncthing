server {
    listen 8385 ssl;
    server_name pi-server.TAILNET.ts.net;

    ssl_certificate /var/lib/tailscale/certs/pi-server.TAILNET.ts.net.crt;
    ssl_certificate_key /var/lib/tailscale/certs/pi-server.TAILNET.ts.net.key;

    location / {
        proxy_pass http://127.0.0.1:8384;
        proxy_set_header Host localhost;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
