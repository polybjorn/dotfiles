server {
    listen 80;
    server_name pi-server.TAILNET.ts.net;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl;
    server_name pi-server.TAILNET.ts.net;

    ssl_certificate /var/lib/tailscale/certs/pi-server.TAILNET.ts.net.crt;
    ssl_certificate_key /var/lib/tailscale/certs/pi-server.TAILNET.ts.net.key;

    root /var/www/pi-dashboard;
    index index.html;

    location /icons/ {
        alias /var/www/pi-dashboard/icons/;
    }

    location /api/ {
        proxy_pass http://127.0.0.1:9999;
    }
}
