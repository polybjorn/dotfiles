#!/usr/bin/env python3
"""qBittorrent seeding cleanup.

Removes torrents that have been seeding for over a threshold
but haven't reached a minimum ratio. Preserves a minimum number
of torrents per tracker to maintain bonus points.

Default: dry-run mode. Use --execute to actually delete.
"""

import argparse
import http.cookiejar
import json
import os
import re
import sys
import urllib.parse
import urllib.request

QB_URL = "http://127.0.0.1:8080"
DEFAULT_MIN_HOURS = 400
DEFAULT_MIN_RATIO = 0.3
DEFAULT_MIN_PER_TRACKER = 15


def create_opener():
    cj = http.cookiejar.CookieJar()
    return urllib.request.build_opener(urllib.request.HTTPCookieProcessor(cj))


def login(opener, username, password):
    data = urllib.parse.urlencode(
        {"username": username, "password": password}
    ).encode()
    req = urllib.request.Request(f"{QB_URL}/api/v2/auth/login", data=data)
    resp = opener.open(req)
    body = resp.read().decode()
    if body.strip() != "Ok.":
        print(f"Login failed: {body}", file=sys.stderr)
        sys.exit(1)


def get_torrents(opener):
    """Get all completed torrents (seeding, stalled, paused)."""
    req = urllib.request.Request(f"{QB_URL}/api/v2/torrents/info")
    resp = opener.open(req)
    all_torrents = json.loads(resp.read().decode())
    # Keep only torrents that have finished downloading
    return [t for t in all_torrents if t.get("completion_on", 0) > 0]


def get_torrent_trackers(opener, torrent_hash):
    """Get tracker list for a single torrent."""
    url = f"{QB_URL}/api/v2/torrents/trackers?hash={torrent_hash}"
    req = urllib.request.Request(url)
    resp = opener.open(req)
    return json.loads(resp.read().decode())


def tracker_site(url):
    """Extract the site (base domain) from a tracker URL.

    Groups multiple announce URLs from the same private tracker together.
    e.g. 'tracker1.example.com' and 'tracker2.example.com' both -> 'example.com'
    """
    parsed = urllib.parse.urlparse(url)
    hostname = parsed.hostname or ""
    parts = hostname.split(".")
    # For most trackers: take last two parts (example.com)
    # For co.uk style TLDs this isn't perfect, but private trackers
    # don't use those
    if len(parts) >= 2:
        return ".".join(parts[-2:])
    return hostname


def is_private_url(url):
    """Detect private tracker URLs by the presence of a passkey.

    Private trackers use passkeys in two common forms:
    - Path: /6ff6eed06b9f5d07aa2a909dab8e3327/announce (hex or alphanumeric)
    - Query: announce.php?passkey=a13daee39d7e873f...
    Public trackers just have /announce with no credentials.
    """
    parsed = urllib.parse.urlparse(url)
    # Passkey in path: a long alphanumeric segment before /announce
    if re.search(r"/[0-9a-zA-Z]{16,}/", parsed.path):
        return True
    # Passkey as query parameter
    if "passkey" in parsed.query:
        return True
    return False


def build_tracker_map(opener, torrents):
    """Map each torrent hash to its private tracker sites.

    Returns:
        hash_to_sites: dict mapping hash -> set of private tracker site domains
        hash_is_private: dict mapping hash -> bool (has at least one private tracker)

    Multiple announce URLs from the same site are grouped together,
    so a torrent on tracker1.example.com and tracker2.example.com
    counts as one site: example.com.
    """
    hash_to_sites = {}
    hash_is_private = {}
    for t in torrents:
        h = t["hash"]
        trackers = get_torrent_trackers(opener, h)
        sites = set()
        private = False
        for tr in trackers:
            url = tr.get("url", "")
            if url.startswith("http") or url.startswith("udp"):
                if is_private_url(url):
                    private = True
                    s = tracker_site(url)
                    if s:
                        sites.add(s)
        hash_to_sites[h] = sites
        hash_is_private[h] = private
    return hash_to_sites, hash_is_private


def fmt_size(b):
    for unit in ("B", "KB", "MB", "GB", "TB"):
        if abs(b) < 1024:
            return f"{b:.1f} {unit}"
        b /= 1024
    return f"{b:.1f} PB"


def fmt_time(seconds):
    hours = seconds / 3600
    if hours >= 48:
        return f"{hours / 24:.0f}d"
    return f"{hours:.0f}h"


def delete_torrents(opener, hashes, delete_files=True):
    data = urllib.parse.urlencode(
        {"hashes": "|".join(hashes), "deleteFiles": str(delete_files).lower()}
    ).encode()
    req = urllib.request.Request(f"{QB_URL}/api/v2/torrents/delete", data=data)
    opener.open(req)


def main():
    p = argparse.ArgumentParser(description="Clean up slow-seeding torrents")
    p.add_argument(
        "--execute", action="store_true", help="Actually delete (default: dry-run)"
    )
    p.add_argument(
        "--min-hours",
        type=float,
        default=DEFAULT_MIN_HOURS,
        help=f"Min seeding hours before evaluation (default: {DEFAULT_MIN_HOURS})",
    )
    p.add_argument(
        "--min-ratio",
        type=float,
        default=DEFAULT_MIN_RATIO,
        help=f"Ratio threshold — delete if below this after min-hours (default: {DEFAULT_MIN_RATIO})",
    )
    p.add_argument(
        "--min-per-tracker",
        type=int,
        default=DEFAULT_MIN_PER_TRACKER,
        help=f"Keep at least this many torrents per tracker for bonus points (default: {DEFAULT_MIN_PER_TRACKER})",
    )
    p.add_argument(
        "--username",
        default=os.environ.get("QB_USERNAME", "admin"),
        help="qBittorrent username (or QB_USERNAME env)",
    )
    p.add_argument(
        "--password",
        default=os.environ.get("QB_PASSWORD"),
        help="qBittorrent password (or QB_PASSWORD env)",
    )
    p.add_argument(
        "--keep-files",
        action="store_true",
        help="Remove torrent but keep files on disk",
    )
    args = p.parse_args()

    if not args.password:
        print(
            "Error: password required. Set QB_PASSWORD env or use --password",
            file=sys.stderr,
        )
        sys.exit(1)

    opener = create_opener()
    login(opener, args.username, args.password)
    torrents = get_torrents(opener)

    # Build tracker map: hash -> set of private tracker sites
    print(f"Fetching tracker info for {len(torrents)} torrents...")
    hash_to_domains, hash_is_private = build_tracker_map(opener, torrents)

    # Count current torrents per private tracker site (across ALL completed torrents)
    tracker_counts = {}
    for domains in hash_to_domains.values():
        for d in domains:
            tracker_counts[d] = tracker_counts.get(d, 0) + 1

    min_seconds = args.min_hours * 3600
    candidates = []
    to_keep_mature = []  # Past threshold but good ratio
    to_keep_young = []  # Not yet past threshold

    for t in torrents:
        seed_time = t.get("seeding_time", 0)
        ratio = t.get("ratio", 0)

        if seed_time < min_seconds:
            to_keep_young.append(t)
        elif ratio >= args.min_ratio:
            to_keep_mature.append(t)
        else:
            candidates.append(t)

    # Sort candidates by ratio (lowest first = least useful deleted first)
    candidates.sort(key=lambda t: t.get("ratio", 0))

    # Filter candidates: skip any whose removal would drop a tracker below the minimum
    to_delete = []
    to_keep_tracker = []  # Kept to preserve tracker minimums
    # Work on a mutable copy of counts to simulate removals
    sim_counts = dict(tracker_counts)

    for t in candidates:
        h = t["hash"]
        domains = hash_to_domains.get(h, set())
        # Public-only torrents: no floor protection, always eligible
        if not hash_is_private.get(h, False):
            to_delete.append(t)
            continue
        # Private torrents: check if removal would drop ANY tracker below minimum
        would_violate = False
        for d in domains:
            if sim_counts.get(d, 0) <= args.min_per_tracker:
                would_violate = True
                break

        if would_violate:
            to_keep_tracker.append(t)
        else:
            to_delete.append(t)
            # Decrement simulated counts
            for d in domains:
                sim_counts[d] = sim_counts.get(d, 0) - 1

    mode = "EXECUTE" if args.execute else "DRY RUN"
    print(f"\n=== qBittorrent Cleanup ({mode}) ===")
    print(f"Rule: seeding > {args.min_hours}h AND ratio < {args.min_ratio}")
    print(f"Tracker floor: keep >= {args.min_per_tracker} torrents per tracker")
    print(
        f"Total: {len(torrents)} completed torrents "
        f"({len(to_keep_young)} young, {len(to_keep_mature)} above ratio, "
        f"{len(to_keep_tracker)} kept for tracker floor, "
        f"{len(to_delete)} to remove)"
    )

    # Count public vs private
    n_public = sum(1 for t in torrents if not hash_is_private.get(t["hash"], False))
    n_private = len(torrents) - n_public

    # Show per-tracker counts (private only — public have no floor)
    print(f"\n  Torrents: {n_private} private, {n_public} public (no floor)")
    if tracker_counts:
        print(f"  Private tracker counts (current -> after cleanup):")
        for domain in sorted(tracker_counts):
            current = tracker_counts[domain]
            after = sim_counts[domain]
            flag = " *" if after <= args.min_per_tracker else ""
            print(f"    {domain:<40} {current:>4} -> {after:>4}{flag}")
    print()

    if not to_delete:
        print("Nothing to delete.")
        return

    total_size = 0
    total_uploaded = 0
    print(
        f"  {'Name':<55} {'Size':>8} {'Ratio':>6} {'Upped':>8} {'Seeding':>8} {'Category':>10}"
    )
    print(f"  {'-' * 101}")
    for t in to_delete:
        name = t.get("name", "?")
        if len(name) > 53:
            name = name[:50] + "..."
        size = t.get("size", 0)
        uploaded = t.get("uploaded", 0)
        total_size += size
        total_uploaded += uploaded
        print(
            f"  {name:<55} {fmt_size(size):>8} "
            f"{t.get('ratio', 0):>6.2f} "
            f"{fmt_size(uploaded):>8} "
            f"{fmt_time(t.get('seeding_time', 0)):>8} "
            f"{t.get('category', '-'):>10}"
        )

    # Also tally the kept torrents for comparison
    kept_uploaded = sum(t.get("uploaded", 0) for t in to_keep_mature + to_keep_young + to_keep_tracker)

    print(f"  {'-' * 101}")
    print(f"  {len(to_delete)} torrents, {fmt_size(total_size)} to reclaim")
    print(f"  Total uploaded by these torrents: {fmt_size(total_uploaded)}")
    print(f"  Total uploaded by kept torrents:  {fmt_size(kept_uploaded)}")

    if to_keep_tracker:
        print(f"\n  {len(to_keep_tracker)} torrents spared to maintain tracker minimums:")
        for t in to_keep_tracker:
            name = t.get("name", "?")
            if len(name) > 60:
                name = name[:57] + "..."
            sites = hash_to_domains.get(t["hash"], set())
            print(f"    {name:<63} ({', '.join(sorted(sites))})")

    if args.execute:
        delete_files = not args.keep_files
        action = "Deleting torrents + files" if delete_files else "Removing torrents (keeping files)"
        print(f"\n{action}...")
        delete_torrents(opener, [t["hash"] for t in to_delete], delete_files)
        print("Done.")
    else:
        print(f"\nDry run complete. Use --execute to delete.")


if __name__ == "__main__":
    main()
