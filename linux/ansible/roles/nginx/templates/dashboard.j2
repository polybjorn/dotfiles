server {
    listen 80;
    server_name {{ tailscale_hostname }};
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl;
    server_name {{ tailscale_hostname }};

    ssl_certificate /var/lib/tailscale/certs/{{ tailscale_hostname }}.crt;
    ssl_certificate_key /var/lib/tailscale/certs/{{ tailscale_hostname }}.key;

    root /var/www/pi-dashboard;
    index index.html;

    location /icons/ {
        alias /var/www/pi-dashboard/icons/;
    }

    location /api/ {
        proxy_pass http://127.0.0.1:9999;
    }
}
