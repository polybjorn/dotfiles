# Managed by Ansible — do not edit manually

{% if ansible_os_family == 'Debian' %}
Include /etc/ssh/sshd_config.d/*.conf
{% endif %}

# Authentication
PermitRootLogin {{ 'prohibit-password' if user_name == 'root' else 'no' }}
PubkeyAuthentication yes
PasswordAuthentication no
KbdInteractiveAuthentication no
MaxAuthTries 3
AllowUsers {{ user_name }}

# Security
X11Forwarding no
PermitEmptyPasswords no
PrintMotd no
UsePAM yes

# Networking
TCPKeepAlive yes
ClientAliveInterval 120
ClientAliveCountMax 3

# Locale
AcceptEnv LANG LC_*

# Subsystems
Subsystem sftp {{ '/usr/lib/openssh/sftp-server' if ansible_os_family == 'Debian' else '/usr/lib/ssh/sftp-server' }}
