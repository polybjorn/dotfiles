      <outline text="styropyro" type="rss" xmlUrl="http://localhost:8085/?action=display&amp;bridge=YoutubeBridge&amp;context=By+channel+id&amp;c=UCJYJgj7rzsn0vdR7fkgjuIA&amp;duration_min=2&amp;duration_max=&amp;format=Atom" htmlUrl="https://www.youtube.com/channel/UCJYJgj7rzsn0vdR7fkgjuIA"/>
